{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node scripts/claude-hook.js"
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node scripts/claude-hook.js",
        "matcher": "Write|Edit|Bash|Read"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node scripts/claude-hook.js"
      }
    ]
  }
}
